# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file.

# --- App ---
ENV=production
DEBUG=false
PROJECT_NAME="Enterprise Auth Server"
API_V1_PREFIX=/api/v1

# --- Security / JWT ---
# Generate a strong secret with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REMEMBER_ME_DAYS=30
PRE_AUTH_TOKEN_EXPIRE_MINUTES=5

# --- Two-Factor Authentication ---
# Fernet key for encrypting TOTP secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key
TWO_FACTOR_ISSUER="Enterprise Auth Server"
TOTP_VALID_WINDOW=1
BACKUP_CODE_COUNT=10
TWO_FA_RATE_LIMIT_PER_MINUTE=5
TWO_FA_MAX_FAILURES=5

# --- Cookies ---
COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# --- Database ---
# Hostname "db" resolves to the postgres service on the docker compose network.
DATABASE_URL=postgresql+asyncpg://auth:auth@db:5432/auth

# --- Redis ---
# Hostname "redis" resolves to the redis service on the docker compose network.
REDIS_URL=redis://redis:6379/0

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting / lockout ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10
MAX_FAILED_LOGINS=5
LOCKOUT_SECONDS=900
