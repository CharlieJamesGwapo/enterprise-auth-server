# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file.

# --- App ---
ENV=production
DEBUG=false
PROJECT_NAME="Enterprise Auth Server"
API_V1_PREFIX=/api/v1

# --- Security / JWT ---
# Generate a strong secret with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REMEMBER_ME_DAYS=30

# --- Cookies ---
COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# --- Database ---
# Hostname "db" resolves to the postgres service on the docker compose network.
DATABASE_URL=postgresql+asyncpg://auth:auth@db:5432/auth

# --- Redis ---
# Hostname "redis" resolves to the redis service on the docker compose network.
REDIS_URL=redis://redis:6379/0

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting / lockout ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10
MAX_FAILED_LOGINS=5
LOCKOUT_SECONDS=900
